# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e configure os valores reais

# Azure
AZURE_APP_NAME=api-azure-devops-seu-nome
AZURE_RESOURCE_GROUP=myResourceGroup
AZURE_LOCATION=eastus

# FastAPI
DEBUG=True
API_TITLE=API Azure DevOps
API_VERSION=1.0.0

# Banco de dados (futuro)
DATABASE_URL=postgresql://user:password@localhost:5432/api_db

# Segurança (futuro)
SECRET_KEY=sua-chave-secreta-aqui
ALLOWED_HOSTS=localhost,127.0.0.1,api-azure-devops-seu-nome.azurewebsites.net
